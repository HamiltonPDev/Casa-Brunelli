# ═══════════════════════════════════════════════════════════════
# Casa Brunelli — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ═══════════════════════════════════════════════════════════════

# ─── Database (Supabase PostgreSQL) ───────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/casa_brunelli?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/casa_brunelli"

# ─── NextAuth.js v5 ────────────────────────────────────────────
AUTH_SECRET="your-secret-key-min-32-chars"
AUTH_URL="http://localhost:3000"

# ─── Stripe ────────────────────────────────────────────────────
STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Resend (Email) ────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@casabrunelli.com"
RESEND_FROM_NAME="Casa Brunelli"

# ─── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Casa Brunelli"

# ─── Admin seed (initial setup only) ──────────────────────────
ADMIN_EMAIL="admin@casabrunelli.com"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Casa Brunelli Admin"
